{
  "info": {
    "name": "FlatMate App API — v3",
    "description": "Complete API collection. Base URL: http://localhost:8081. Set 'token' variable after login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",   "value": "http://localhost:8081" },
    { "key": "token",     "value": "<paste accessToken here after login>" },
    { "key": "userId",    "value": "user_001" },
    { "key": "ownerId",   "value": "owner_001" },
    { "key": "seekerId",  "value": "seeker_001" },
    { "key": "listingId", "value": "listing_001" },
    { "key": "matchId",   "value": "match_001" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "1. Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/otp/send", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "send"] },
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+919876543210\"\n}" }
          }
        },
        {
          "name": "2. Verify OTP → Get Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/otp/verify", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "verify"] },
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+919876543210\",\n  \"otp\": \"123456\"\n}" },
            "description": "Returns { accessToken, refreshToken, userId, isNewUser }. If isNewUser=true call Set Role next."
          }
        },
        {
          "name": "3. Google Login → Get Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/social/google", "host": ["{{baseUrl}}"], "path": ["auth", "social", "google"] },
            "body": { "mode": "raw", "raw": "{\n  \"idToken\": \"<GOOGLE_ID_TOKEN_FROM_CLIENT>\"\n}" }
          }
        },
        {
          "name": "4. Apple Login → Get Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/social/apple", "host": ["{{baseUrl}}"], "path": ["auth", "social", "apple"] },
            "body": { "mode": "raw", "raw": "{\n  \"appleId\": \"apple_user_12345\",\n  \"email\": \"user@icloud.com\"\n}" }
          }
        },
        {
          "name": "5. Set Role — SEEKER or OWNER ⭐",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/set-role", "host": ["{{baseUrl}}"], "path": ["auth", "set-role"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"role\": \"OWNER\"\n}" },
            "description": "Call after login if isNewUser=true. role = SEEKER or OWNER. Tracks role history if switching."
          }
        },
        {
          "name": "6. Refresh Access Token ⭐",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"<paste refreshToken here>\"\n}" }
          }
        }
      ]
    },
    {
      "name": "👤 User Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/profiles/{{userId}}", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}"] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"name\": \"Ravi Kumar\",\n  \"email\": \"ravi@example.com\",\n  \"phone\": \"+919876543210\",\n  \"bio\": \"Looking for a flat near Koramangala.\",\n  \"profilePic\": \"https://s3.amazonaws.com/flatmate/profiles/user_001.jpg\"\n}" }
          }
        },
        {
          "name": "Register as Owner",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/profiles/{{userId}}/owner", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}", "owner"] }
          }
        },
        {
          "name": "Get Role Change History ⭐",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/profiles/{{userId}}/role-history", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}", "role-history"] }
          }
        }
      ]
    },
    {
      "name": "🏠 Listings",
      "item": [
        {
          "name": "1. Publish Listing (Min 5 Photos) ⭐ FULL FORM",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/listings", "host": ["{{baseUrl}}"], "path": ["listings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerId\": \"{{ownerId}}\",\n\n  \"placeType\": \"APARTMENT\",\n  \"roomType\": \"PRIVATE_ROOM\",\n\n  \"availableFrom\": \"2026-04-01\",\n  \"furnishingStatus\": \"FULLY_FURNISHED\",\n  \"totalFloors\": 6,\n  \"propertyOnFloor\": \"FIRST\",\n  \"floorPlan\": \"2BHK\",\n  \"floorType\": \"SINGLE\",\n  \"balconyAvailable\": true,\n  \"ageOfProperty\": \"1_5_YEARS\",\n  \"carParking\": 1,\n  \"bikeParking\": 2,\n\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946,\n  \"showPreciseLocation\": false,\n  \"country\": \"India\",\n  \"flatHouseDetails\": \"Flat 4B\",\n  \"streetAddress\": \"Akshya Nagar 1st Block 1st Cross\",\n  \"landmark\": \"Near Rammurthy Nagar Bus Stop\",\n  \"district\": \"Rammurthy Nagar\",\n  \"pinCode\": \"560016\",\n  \"city\": \"Bangalore\",\n\n  \"bathroomType\": \"ATTACHED\",\n  \"occupantType\": \"ONLY_ME\",\n\n  \"lights\": 4,\n  \"fans\": 3,\n  \"ac\": 2,\n  \"tv\": 1,\n  \"beds\": 2,\n  \"wardrobes\": 2,\n  \"geysers\": 1,\n  \"amenities\": [\"Wifi\", \"Sofa\", \"Washing Machine\", \"Stove\", \"Water Purifier\", \"Dining Table\"],\n  \"customAmenities\": [\"Study Table\", \"Curtains\"],\n  \"description\": \"Spacious 2BHK. Quiet gated society. 24x7 water supply.\",\n\n  \"petsAllowed\": false,\n  \"drinkingAllowed\": false,\n  \"smokingAllowed\": false,\n  \"powerBackup\": true,\n\n  \"photos\": [\n    \"https://s3.ap-south-1.amazonaws.com/flatmate/l1/p1.jpg\",\n    \"https://s3.ap-south-1.amazonaws.com/flatmate/l1/p2.jpg\",\n    \"https://s3.ap-south-1.amazonaws.com/flatmate/l1/p3.jpg\",\n    \"https://s3.ap-south-1.amazonaws.com/flatmate/l1/p4.jpg\",\n    \"https://s3.ap-south-1.amazonaws.com/flatmate/l1/p5.jpg\"\n  ],\n\n  \"rent\": 15000,\n  \"minRent\": 12000,\n  \"maxRent\": 18000,\n  \"noticePeriod\": \"2_MONTHS\",\n\n  \"genderPreference\": \"ANY\",\n  \"roomsAvailable\": 1,\n  \"occupancy\": 2\n}"
            },
            "description": "Requires min 5 photos. advanceAmount (=10x rent) is auto-calculated by backend. ownerOnboardingComplete set to true."
          }
        },
        {
          "name": "2. Save as Draft ⭐",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/listings/draft", "host": ["{{baseUrl}}"], "path": ["listings", "draft"] },
            "body": { "mode": "raw", "raw": "{\n  \"ownerId\": \"{{ownerId}}\",\n  \"placeType\": \"APARTMENT\",\n  \"city\": \"Bangalore\",\n  \"availableFrom\": \"2026-04-01\"\n}" },
            "description": "No photo validation. Saves with status=DRAFT."
          }
        },
        {
          "name": "3. Update Listing ⭐",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"ownerId\": \"{{ownerId}}\",\n  \"rent\": 17000,\n  \"petsAllowed\": true,\n  \"description\": \"Updated after renovation.\"\n}" }
          }
        },
        {
          "name": "4. Deactivate Listing (Soft Delete) ⭐",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] },
            "description": "Sets status=DEACTIVATED. Does not delete from DynamoDB."
          }
        },
        {
          "name": "5. Get All Listings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/listings", "host": ["{{baseUrl}}"], "path": ["listings"] }
          }
        },
        {
          "name": "6. Get Listing by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] }
          }
        },
        {
          "name": "7. Get My Listings (by Owner) ⭐",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/listings/owner/{{ownerId}}", "host": ["{{baseUrl}}"], "path": ["listings", "owner", "{{ownerId}}"] }
          }
        },
        {
          "name": "8. Get Upload URL — Photo (JPEG/PNG/HEIC)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}/upload-url?fileName=photo1.jpg", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}", "upload-url"], "query": [{ "key": "fileName", "value": "photo1.jpg" }] }
          }
        },
        {
          "name": "9. Get Upload URL — Video Tour (MP4/MOV)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}/upload-url?fileName=tour.mp4", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}", "upload-url"], "query": [{ "key": "fileName", "value": "tour.mp4" }] }
          }
        }
      ]
    },
    {
      "name": "📍 Location",
      "item": [
        {
          "name": "Index Listing (Geo)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/location/index", "host": ["{{baseUrl}}"], "path": ["location", "index"] },
            "body": { "mode": "raw", "raw": "{\n  \"listingId\": \"{{listingId}}\",\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946\n}" }
          }
        },
        {
          "name": "Find Nearby Listings (GPS only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/location/nearby?lat=12.9716&lng=77.5946&radius=10.0",
              "host": ["{{baseUrl}}"], "path": ["location", "nearby"],
              "query": [
                { "key": "lat", "value": "12.9716" },
                { "key": "lng", "value": "77.5946" },
                { "key": "radius", "value": "10.0" }
              ]
            }
          }
        },
        {
          "name": "Find Nearby Listings (With Filters) ⭐",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/location/nearby?lat=12.9716&lng=77.5946&radius=15.0&minRent=8000&maxRent=20000&genderPreference=ANY&minRooms=1",
              "host": ["{{baseUrl}}"], "path": ["location", "nearby"],
              "query": [
                { "key": "lat", "value": "12.9716" },
                { "key": "lng", "value": "77.5946" },
                { "key": "radius", "value": "15.0" },
                { "key": "minRent", "value": "8000" },
                { "key": "maxRent", "value": "20000" },
                { "key": "genderPreference", "value": "ANY" },
                { "key": "minRooms", "value": "1" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "👍 Swipe",
      "item": [
        {
          "name": "Record Swipe",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/swipes", "host": ["{{baseUrl}}"], "path": ["swipes"] },
            "body": { "mode": "raw", "raw": "{\n  \"seekerId\": \"{{seekerId}}\",\n  \"listingId\": \"{{listingId}}\",\n  \"type\": \"RIGHT\"\n}" },
            "description": "type: RIGHT (interested) or LEFT. Free users: 3/day and 12 total."
          }
        }
      ]
    },
    {
      "name": "🤝 Matches",
      "item": [
        {
          "name": "Approve Match",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/matches/approve", "host": ["{{baseUrl}}"], "path": ["matches", "approve"] },
            "body": { "mode": "raw", "raw": "{\n  \"seekerId\": \"{{seekerId}}\",\n  \"ownerId\": \"{{ownerId}}\"\n}" }
          }
        },
        {
          "name": "Get My Matches",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/matches/{{userId}}", "host": ["{{baseUrl}}"], "path": ["matches", "{{userId}}"] }
          }
        }
      ]
    },
    {
      "name": "💬 Chat (REST)",
      "item": [
        {
          "name": "Get Chat History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/chat/{{matchId}}/history", "host": ["{{baseUrl}}"], "path": ["chat", "{{matchId}}", "history"] }
          }
        },
        {
          "name": "Mark as Read",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/chat/read", "host": ["{{baseUrl}}"], "path": ["chat", "read"] },
            "body": { "mode": "raw", "raw": "{\n  \"seekerId\": \"{{seekerId}}\",\n  \"ownerId\": \"{{ownerId}}\",\n  \"role\": \"SEEKER\"\n}" }
          }
        },
        {
          "name": "Get Chat Media Upload URL",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/chat/upload-url?fileName=image.jpg", "host": ["{{baseUrl}}"], "path": ["chat", "upload-url"], "query": [{ "key": "fileName", "value": "image.jpg" }] }
          }
        }
      ]
    },
    {
      "name": "💬 Chat (WebSocket — STOMP)",
      "description": "Connect: ws://localhost:8081/chat-socket. Subscribe: /topic/match/{matchId}",
      "item": [
        {
          "name": "WS — Send Message [/app/chat]",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/app/chat", "host": ["{{baseUrl}}"], "path": ["app", "chat"] },
            "body": { "mode": "raw", "raw": "{\n  \"matchId\": \"{{matchId}}\",\n  \"senderId\": \"{{seekerId}}\",\n  \"content\": \"Hi! Interested in your flat.\",\n  \"type\": \"TEXT\"\n}" },
            "description": "STOMP WebSocket — not regular HTTP."
          }
        },
        {
          "name": "WS — Typing Indicator [/app/chat/typing]",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/app/chat/typing", "host": ["{{baseUrl}}"], "path": ["app", "chat", "typing"] },
            "body": { "mode": "raw", "raw": "{\n  \"matchId\": \"{{matchId}}\",\n  \"senderId\": \"{{seekerId}}\",\n  \"isTyping\": \"true\"\n}" }
          }
        }
      ]
    },
    {
      "name": "🔔 Notifications",
      "item": [
        {
          "name": "Register FCM Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/notifications/token", "host": ["{{baseUrl}}"], "path": ["notifications", "token"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"token\": \"fcm-device-token-abc123\"\n}" }
          }
        },
        {
          "name": "Send Notification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/notifications/send", "host": ["{{baseUrl}}"], "path": ["notifications", "send"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"title\": \"New Match!\",\n  \"body\": \"Someone is interested in your flat.\"\n}" }
          }
        },
        {
          "name": "Get Inbox",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/notifications/inbox/{{userId}}", "host": ["{{baseUrl}}"], "path": ["notifications", "inbox", "{{userId}}"] }
          }
        }
      ]
    },
    {
      "name": "💳 Payments",
      "item": [
        {
          "name": "Subscribe",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/payments/subscribe", "host": ["{{baseUrl}}"], "path": ["payments", "subscribe"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"planId\": \"PREMIUM_MONTHLY\"\n}" }
          }
        },
        {
          "name": "Razorpay Webhook",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/payments/webhook", "host": ["{{baseUrl}}"], "path": ["payments", "webhook"] },
            "body": { "mode": "raw", "raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": { \"payment\": { \"entity\": { \"id\": \"pay_abc123\", \"amount\": 49900 } } }\n}" }
          }
        }
      ]
    }
  ]
}