              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+919876543210\",\n  \"otp\": \"123456\"\n}"
            },
            "description": "Returns accessToken, refreshToken, roles, activeRole and onboarding flags."
          }
        },
        {
          "name": "3. Refresh Token",
          "request": {
            "method": "POST",
            "header": [
