{
  "info": {
    "name": "FlatMate App API — v5",
    "description": "Complete API collection. Base URL: https://hjqqy3z9r1.execute-api.ap-south-1.amazonaws.com/prod (production) or http://localhost:8081 (local). Set 'token' variable after login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",   "value": "https://hjqqy3z9r1.execute-api.ap-south-1.amazonaws.com/prod", "description": "AWS API Gateway Production Endpoint" },
    { "key": "token",     "value": "<paste accessToken here after login>" },
    { "key": "refreshToken", "value": "<paste refreshToken here after login>" },
    { "key": "userId",    "value": "user_001" },
    { "key": "ownerId",   "value": "owner_001" },
    { "key": "seekerId",  "value": "seeker_001" },
    { "key": "listingId", "value": "listing_001" },
    { "key": "matchId",   "value": "match_001" },
    { "key": "kycDocumentUrl", "value": "https://s3.amazonaws.com/flatmate-photos/kyc/user_001/aadhar-front.jpg" },
    { "key": "kycSelfieUrl",   "value": "https://s3.amazonaws.com/flatmate-photos/kyc/user_001/selfie.jpg" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "1. Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/otp/send", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "send"] },
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+919876543210\"\n}" }
          }
        },
        {
          "name": "2. Verify OTP -> Get Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/otp/verify", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "verify"] },
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+919876543210\",\n  \"otp\": \"123456\"\n}" },
            "description": "Returns { accessToken, refreshToken, userId, isNewUser }. For OTP users, userId is the phone number. If isNewUser=true continue onboarding. If isNewUser=false the user is fully onboarded."
          }
        },
        {
          "name": "3. Set Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/set-role", "host": ["{{baseUrl}}"], "path": ["auth", "set-role"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"role\": \"SEEKER\"\n}" },
            "description": "Accepted role values: SEEKER, OWNER, TENANT, HOST. TENANT maps to SEEKER. HOST maps to OWNER."
          }
        },
        {
          "name": "4. Refresh Access Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "5. Switch Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/switch-role", "host": ["{{baseUrl}}"], "path": ["auth", "switch-role"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"role\": \"TENANT\"\n}" }
          }
        }
      ]
    },
    {
      "name": "👤 Profile — Basic Info (All Users)",
      "item": [
        {
          "name": "1. Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/profiles/{{userId}}", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}"] }
          }
        },
        {
          "name": "2. Update Basic Info (Step 1 — All Users)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"firstName\": \"Rajasekar\",\n  \"lastName\": \"Kumar\",\n  \"dateOfBirth\": \"1995-06-15\",\n  \"gender\": \"MAN\",\n  \"description\": \"I am a software engineer looking for a 2BHK near Koramangala.\"\n}"
            },
            "description": "Step 1 for both SEEKER and OWNER after role selection. 'description' is the user bio/about-me field."
          }
        },
        {
          "name": "3. Upload Profile Photo → Get S3 URL",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/listings/{{listingId}}/upload-url?fileName=profile_photo.jpg",
              "host": ["{{baseUrl}}"],
              "path": ["listings", "{{listingId}}", "upload-url"],
              "query": [{ "key": "fileName", "value": "profile_photo.jpg" }]
            },
            "description": "Get a pre-signed S3 URL. Then PUT the image bytes directly to that URL. Then set profilePic in Update Basic Info."
          }
        },
        {
          "name": "4. Update Profile Photo URL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"profilePic\": \"https://s3.amazonaws.com/flatmate-photos/users/user_001/profile_photo.jpg\"\n}"
            }
          }
        },
        {
          "name": "5. Get Role History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/profiles/{{userId}}/role-history", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}", "role-history"] }
          }
        },
        {
          "name": "6. Get KYC Upload URL",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/profiles/{{userId}}/kyc/upload-url?fileName=aadhar-front.jpg&type=document",
              "host": ["{{baseUrl}}"],
              "path": ["profiles", "{{userId}}", "kyc", "upload-url"],
              "query": [
                { "key": "fileName", "value": "aadhar-front.jpg" },
                { "key": "type", "value": "document" }
              ]
            },
            "description": "Call once with type=document and once with type=selfie. Upload the file bytes to the returned url, then use the returned filePath in /profiles/kyc."
          }
        },
        {
          "name": "7. Complete KYC (Both Roles)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/profiles/kyc", "host": ["{{baseUrl}}"], "path": ["profiles", "kyc"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"documentType\": \"AADHAR_CARD\",\n  \"documentImageUrl\": \"{{kycDocumentUrl}}\",\n  \"selfieImageUrl\": \"{{kycSelfieUrl}}\"\n}"
            },
            "description": "Use after profile data is completed. Allowed documentType values: AADHAR_CARD, DRIVING_LICENSE, VOTER_ID, PASSPORT."
          }
        }
      ]
    },
    {
      "name": "🔍 Seeker Onboarding (Tenant Only)",
      "item": [
        {
          "name": "1. Save Location (Map Pin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"seekerProfile\": {\n    \"location\": {\n      \"latitude\": 12.9716,\n      \"longitude\": 77.5946,\n      \"formattedAddress\": \"Akshya Nagar 1st Block 1st Cross, Rammurthy nagar, Bangalore-560016\"\n    }\n  }\n}"
            },
            "description": "User drags map pin to their current location. Save lat/lng and formatted address."
          }
        },
        {
          "name": "2. Save Education & Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"seekerProfile\": {\n    \"education\": \"Bachelor's\",\n    \"jobTitle\": \"Software Engineer\",\n    \"companyName\": \"TCS\"\n  }\n}"
            }
          }
        },
        {
          "name": "3. Save Languages",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"seekerProfile\": {\n    \"knownLanguages\": [\"Tamil\", \"English\", \"Hindi\"]\n  }\n}"
            }
          }
        },
        {
          "name": "4. Save Lifestyle Preferences",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"seekerProfile\": {\n    \"smokingHabit\": \"NEVER\",\n    \"drinkingHabit\": \"SOMETIMES\",\n    \"foodHabit\": \"NON_VEGETARIAN\",\n    \"maritalStatus\": \"SINGLE\",\n    \"petHabit\": \"NO_PETS\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "smokingHabit: OPEN_TO_ALL | REGULARLY | NEVER | SOMETIMES\ndrinkingHabit: OPEN_TO_ALL | REGULARLY | NEVER | SOMETIMES\nfoodHabit: NON_VEGETARIAN | VEGETARIAN | EGGETARIAN | VEGAN | PESCATARIAN\nmaritalStatus: SINGLE | SINGLE_KIDS | DIVORCED | DIVORCED_KIDS | WIDOWED | WIDOWED_KIDS | SEPARATED | SEPARATED_KIDS\npetHabit: HAS_PETS | NO_PETS"
          }
        },
        {
          "name": "5. Save Full Seeker Profile (All at once)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"firstName\": \"Rajasekar\",\n  \"lastName\": \"Kumar\",\n  \"dateOfBirth\": \"1995-06-15\",\n  \"gender\": \"MAN\",\n  \"profilePic\": \"https://s3.amazonaws.com/flatmate-photos/users/user_001/profile.jpg\",\n  \"seekerProfile\": {\n    \"education\": \"Bachelor's\",\n    \"jobTitle\": \"Software Engineer\",\n    \"companyName\": \"TCS\",\n    \"knownLanguages\": [\"Tamil\", \"English\", \"Hindi\"],\n    \"smokingHabit\": \"NEVER\",\n    \"drinkingHabit\": \"SOMETIMES\",\n    \"foodHabit\": \"NON_VEGETARIAN\",\n    \"maritalStatus\": \"SINGLE\",\n    \"petHabit\": \"NO_PETS\",\n    \"location\": {\n      \"latitude\": 12.9716,\n      \"longitude\": 77.5946,\n      \"formattedAddress\": \"Akshya Nagar 1st Block 1st Cross, Rammurthy nagar, Bangalore-560016\"\n    }\n  }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🏠 Owner — Listing APIs",
      "item": [
        {
          "name": "1. Publish Listing (Full — 11 Steps)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/listings", "host": ["{{baseUrl}}"], "path": ["listings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerId\": \"{{ownerId}}\",\n  \"placeType\": \"APARTMENT\",\n  \"roomType\": \"A_ROOM\",\n  \"availableFrom\": \"2026-04-01\",\n  \"furnishingStatus\": \"SEMI_FURNISHED\",\n  \"totalFloors\": 6,\n  \"propertyFloor\": \"FIRST_FLOOR\",\n  \"bhkType\": \"2BHK\",\n  \"floorType\": \"SINGLE_FLOOR\",\n  \"balconyAvailable\": true,\n  \"ageOfProperty\": \"0_TO_1_YEARS\",\n  \"carParking\": 1,\n  \"bikeParking\": 2,\n  \"addressLine1\": \"Akshya Nagar 1st Block 1st Cross\",\n  \"area\": \"Rammurthy nagar\",\n  \"city\": \"Bangalore\",\n  \"state\": \"Karnataka\",\n  \"pincode\": \"560016\",\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946,\n  \"bathroomType\": \"ATTACHED\",\n  \"amenities\": [\"WiFi\", \"AC\", \"Washing Machine\"],\n  \"coOccupants\": \"MALE_ONLY\",\n  \"houseRules\": \"No parties. No smoking inside.\",\n  \"photos\": [\n    \"https://s3.amazonaws.com/flatmate-photos/listings/listing_001/photo_1.jpg\",\n    \"https://s3.amazonaws.com/flatmate-photos/listings/listing_001/photo_2.jpg\",\n    \"https://s3.amazonaws.com/flatmate-photos/listings/listing_001/photo_3.jpg\",\n    \"https://s3.amazonaws.com/flatmate-photos/listings/listing_001/photo_4.jpg\",\n    \"https://s3.amazonaws.com/flatmate-photos/listings/listing_001/photo_5.jpg\"\n  ],\n  \"monthlyRent\": 15000,\n  \"maintenanceCharges\": 500,\n  \"noticePeriodMonths\": 2\n}"
            }
          }
        },
        {
          "name": "2. Save Draft Listing",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/listings/draft", "host": ["{{baseUrl}}"], "path": ["listings", "draft"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerId\": \"{{ownerId}}\",\n  \"placeType\": \"APARTMENT\",\n  \"monthlyRent\": 15000\n}"
            }
          }
        },
        {
          "name": "3. Get Photo/Video Upload URL",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/listings/{{listingId}}/upload-url?fileName=photo_1.jpg",
              "host": ["{{baseUrl}}"],
              "path": ["listings", "{{listingId}}", "upload-url"],
              "query": [{ "key": "fileName", "value": "photo_1.jpg" }]
            },
            "description": "Step 1: Call this per photo (5 times for 5 photos). Returns { uploadUrl, filePath }.\nStep 2: PUT photo bytes directly to uploadUrl (no auth header needed).\nStep 3: Include all filePaths in 'photos' array when publishing listing."
          }
        },
        {
          "name": "4. Update Listing",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"monthlyRent\": 16000,\n  \"houseRules\": \"Updated rules\"\n}" }
          }
        },
        {
          "name": "5. Get All Listings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/listings", "host": ["{{baseUrl}}"], "path": ["listings"] }
          }
        },
        {
          "name": "6. Get Single Listing",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] }
          }
        },
        {
          "name": "7. Get Owner's Listings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/listings/owner/{{ownerId}}", "host": ["{{baseUrl}}"], "path": ["listings", "owner", "{{ownerId}}"] }
          }
        },
        {
          "name": "8. Deactivate Listing",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] }
          }
        }
      ]
    },
    {
      "name": "📍 Location / Nearby Search",
      "item": [
        {
          "name": "1. Find Nearby Listings (GPS)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/listings/nearby?lat=12.9716&lng=77.5946&radiusKm=5",
              "host": ["{{baseUrl}}"],
              "path": ["listings", "nearby"],
              "query": [
                { "key": "lat", "value": "12.9716" },
                { "key": "lng", "value": "77.5946" },
                { "key": "radiusKm", "value": "5" }
              ]
            },
            "description": "Returns listings within the given radius from the seeker's GPS coordinates."
          }
        }
      ]
    },
    {
      "name": "💬 Chat",
      "item": [
        {
          "name": "1. Send Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/chat/send", "host": ["{{baseUrl}}"], "path": ["chat", "send"] },
            "body": { "mode": "raw", "raw": "{\n  \"senderId\": \"{{userId}}\",\n  \"receiverId\": \"other_user_id\",\n  \"content\": \"Hi, is the flat still available?\"\n}" }
          }
        },
        {
          "name": "2. Get Chat History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/chat/history?user1={{userId}}&user2=other_user_id",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "history"],
              "query": [
                { "key": "user1", "value": "{{userId}}" },
                { "key": "user2", "value": "other_user_id" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "❤️ Swipe & Match",
      "item": [
        {
          "name": "1. Swipe on Listing",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/swipes", "host": ["{{baseUrl}}"], "path": ["swipes"] },
            "body": { "mode": "raw", "raw": "{\n  \"seekerId\": \"{{seekerId}}\",\n  \"listingId\": \"{{listingId}}\",\n  \"direction\": \"RIGHT\"\n}" }
          }
        },
        {
          "name": "2. Get Matches",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/matches/{{userId}}", "host": ["{{baseUrl}}"], "path": ["matches", "{{userId}}"] }
          }
        }
      ]
    },
    {
      "name": "🔔 Notifications",
      "item": [
        {
          "name": "1. Register Device Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/notifications/device-token", "host": ["{{baseUrl}}"], "path": ["notifications", "device-token"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"token\": \"<FCM_DEVICE_TOKEN>\",\n  \"platform\": \"ANDROID\"\n}" }
          }
        }
      ]
    }
  ]
}
