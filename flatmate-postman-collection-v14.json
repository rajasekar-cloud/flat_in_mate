{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d",
    "name": "FlatMate App API - v14 (Final Consolidated)",
    "description": "Complete consolidated Postman collection for the FlatMate App. Includes Auth, Profiles, KYC (Manual & SurePass), Listings, Location, Swipes, Matches, Chat, Notifications, and Payments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userId", "value": "+919876543210", "type": "string" },
    { "key": "listingId", "value": "listing_001", "type": "string" },
    { "key": "matchId", "value": "match_001", "type": "string" },
    { "key": "seekerId", "value": "+910000000000", "type": "string" },
    { "key": "ownerId", "value": "+919876543210", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "1. Health",
      "item": [
        {
          "name": "Get Health Status",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "2. Auth",
      "item": [
        {
          "name": "1. Send OTP",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{userId}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/auth/otp/send", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "send"] }
          }
        },
        {
          "name": "2. Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) pm.collectionVariables.set('token', json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{userId}}\",\n  \"otp\": \"123456\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/auth/otp/verify", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "verify"] }
          }
        },
        {
          "name": "3. Refresh Token",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "4. Set Role (Onboarding)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"role\": \"SEEKER\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/auth/set-role", "host": ["{{baseUrl}}"], "path": ["auth", "set-role"] }
          }
        },
        {
          "name": "5. Switch Active Role",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"role\": \"OWNER\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/auth/switch-role", "host": ["{{baseUrl}}"], "path": ["auth", "switch-role"] }
          }
        }
      ]
    },
    {
      "name": "3. User Profile",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/profiles/{{userId}}", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}"] }
          }
        },
        {
          "name": "Update Basic Info",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"firstName\": \"Raj\",\n  \"lastName\": \"Kumar\",\n  \"dateOfBirth\": \"1995-01-01\",\n  \"gender\": \"MAN\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] }
          }
        },
        {
          "name": "Update Seeker Lifestyle",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"seekerProfile\": {\n    \"education\": \"B.Tech\",\n    \"jobTitle\": \"Software Engineer\",\n    \"companyName\": \"Google\",\n    \"smokingHabit\": \"NEVER\",\n    \"drinkingHabit\": \"SOCIALLY\",\n    \"petHabit\": \"DOG_LOVER\"\n  }\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] }
          }
        },
        {
          "name": "Get KYC Presigned URL",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/profiles/{{userId}}/kyc/upload-url?fileName=aadhar.jpg&type=document", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}", "kyc", "upload-url"], "query": [ { "key": "fileName", "value": "aadhar.jpg" }, { "key": "type", "value": "document" } ] }
          }
        },
        {
          "name": "Submit Manual KYC",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"documentType\": \"AADHAR_CARD\",\n  \"documentImageUrl\": \"s3_url_here\",\n  \"selfieImageUrl\": \"s3_url_here\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/profiles/kyc", "host": ["{{baseUrl}}"], "path": ["profiles", "kyc"] }
          }
        },
        {
          "name": "Register As Owner",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/profiles/{{userId}}/owner", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}", "owner"] }
          }
        }
      ]
    },
    {
      "name": "4. KYC (SurePass)",
      "item": [
        {
          "name": "Aadhaar: 1. Generate OTP",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"aadhaarNumber\": \"123456789012\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/profiles/kyc/aadhaar/generate-otp", "host": ["{{baseUrl}}"], "path": ["profiles", "kyc", "aadhaar", "generate-otp"] }
          }
        },
        {
          "name": "Aadhaar: 2. Verify OTP",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"clientId\": \"client_id_from_step_1\",\n  \"otp\": \"123456\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/profiles/kyc/aadhaar/verify-otp", "host": ["{{baseUrl}}"], "path": ["profiles", "kyc", "aadhaar", "verify-otp"] }
          }
        },
        {
          "name": "PAN: Verify",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"panNumber\": \"ABCDE1234F\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/profiles/kyc/pan/verify", "host": ["{{baseUrl}}"], "path": ["profiles", "kyc", "pan", "verify"] }
          }
        },
        {
          "name": "DL: Verify",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"dlNumber\": \"SS1234567890123\",\n  \"dob\": \"1995-01-01\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/profiles/kyc/dl/verify", "host": ["{{baseUrl}}"], "path": ["profiles", "kyc", "dl", "verify"] }
          }
        },
        {
          "name": "Voter ID: Verify",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"voterId\": \"XYZ1234567\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/profiles/kyc/voter/verify", "host": ["{{baseUrl}}"], "path": ["profiles", "kyc", "voter", "verify"] }
          }
        }
      ]
    },
    {
      "name": "5. Listings",
      "item": [
        {
          "name": "Publish New Listing",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"ownerId\": \"{{userId}}\",\n  \"propertyName\": \"Ocean View Apartments\",\n  \"placeType\": \"APARTMENT\",\n  \"roomType\": \"PRIVATE_ROOM\",\n  \"rent\": 25000,\n  \"city\": \"Mumbai\",\n  \"latitude\": 19.076,\n  \"longitude\": 72.877\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/listings", "host": ["{{baseUrl}}"], "path": ["listings"] }
          }
        },
        {
          "name": "Get All Listings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/listings", "host": ["{{baseUrl}}"], "path": ["listings"] }
          }
        },
        {
          "name": "Get Listing by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] }
          }
        },
        {
          "name": "Get Owner's Listings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/listings/owner/{{userId}}", "host": ["{{baseUrl}}"], "path": ["listings", "owner", "{{userId}}"] }
          }
        },
        {
          "name": "Update Listing",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"propertyName\": \"Updated Ocean View\",\n  \"rent\": 27000\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] }
          }
        },
        {
          "name": "Delete Listing",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] }
          }
        }
      ]
    },
    {
      "name": "6. Location",
      "item": [
        {
          "name": "Index Locations (Backfill)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/location/index", "host": ["{{baseUrl}}"], "path": ["location", "index"] }
          }
        },
        {
          "name": "Search Nearby Listings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/location/nearby?lat=19.07&lng=72.87&radius=10", "host": ["{{baseUrl}}"], "path": ["location", "nearby"], "query": [ { "key": "lat", "value": "19.07" }, { "key": "lng", "value": "72.87" }, { "key": "radius", "value": "10" } ] }
          }
        }
      ]
    },
    {
      "name": "7. Swipes & Matches",
      "item": [
        {
          "name": "Swipe RIGHT on Listing",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"seekerId\": \"{{userId}}\",\n  \"listingId\": \"{{listingId}}\",\n  \"swipeType\": \"RIGHT\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/swipes", "host": ["{{baseUrl}}"], "path": ["swipes"] }
          }
        },
        {
          "name": "Get Listing Interests (Owner view)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/swipes/listing/{{listingId}}/interests", "host": ["{{baseUrl}}"], "path": ["swipes", "listing", "{{listingId}}", "interests"] }
          }
        },
        {
          "name": "Approve Match",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"ownerId\": \"{{userId}}\",\n  \"seekerId\": \"{{seekerId}}\",\n  \"listingId\": \"{{listingId}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/matches/approve", "host": ["{{baseUrl}}"], "path": ["matches", "approve"] }
          }
        },
        {
          "name": "Get My Active Matches",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/matches/{{userId}}", "host": ["{{baseUrl}}"], "path": ["matches", "{{userId}}"] }
          }
        }
      ]
    },
    {
      "name": "8. Chat",
      "item": [
        {
          "name": "Get Chat History",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/chat/{{matchId}}/history", "host": ["{{baseUrl}}"], "path": ["chat", "{{matchId}}", "history"] }
          }
        },
        {
          "name": "Mark Messages as Read",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/chat/{{matchId}}/read?userId={{userId}}", "host": ["{{baseUrl}}"], "path": ["chat", "{{matchId}}", "read"], "query": [ { "key": "userId", "value": "{{userId}}" } ] }
          }
        },
        {
          "name": "Get Chat Media Upload URL",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/chat/{{matchId}}/upload-url?fileName=image.jpg", "host": ["{{baseUrl}}"], "path": ["chat", "{{matchId}}", "upload-url"], "query": [ { "key": "fileName", "value": "image.jpg" } ] }
          }
        }
      ]
    },
    {
      "name": "9. Notifications",
      "item": [
        {
          "name": "Get Inbox Notifications",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/notifications/inbox/{{userId}}", "host": ["{{baseUrl}}"], "path": ["notifications", "inbox", "{{userId}}"] }
          }
        },
        {
          "name": "Save FCM Token",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"fcmToken\": \"fcm_token_device_abc\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/notifications/token", "host": ["{{baseUrl}}"], "path": ["notifications", "token"] }
          }
        }
      ]
    },
    {
      "name": "10. Payments",
      "item": [
        {
          "name": "Create Subscription Order",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"planId\": \"premium_monthly\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/payments/orders", "host": ["{{baseUrl}}"], "path": ["payments", "orders"] }
          }
        }
      ]
    }
  ]
}
