{
    "info": {
        "name": "FlatMate Platform (Step 1: Auth Focus)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Authentication (Priority)",
            "item": [
                {
                    "name": "Option 1: OTP - Send",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"phone\": \"+919999999999\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "http://localhost:8081/auth/otp/send"
                    }
                },
                {
                    "name": "Option 1: OTP - Verify",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"phone\": \"+919999999999\",\n    \"otp\": \"123456\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "http://localhost:8081/auth/otp/verify"
                    }
                },
                {
                    "name": "Option 2: Gmail Login (Google)",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"idToken\": \"YOUR_GOOGLE_ID_TOKEN_HERE\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "http://localhost:8081/auth/social/google"
                    }
                },
                {
                    "name": "Option 3: Apple Login",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"appleId\": \"apple_user_id\",\n    \"email\": \"user@apple.com\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "http://localhost:8081/auth/social/apple"
                    }
                }
            ]
        },
        {
            "name": "2. Listings & Maps",
            "item": [
                {
                    "name": "Create Listing",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"id\": \"list_001\",\n    \"ownerId\": \"user_123\",\n    \"description\": \"Luxury 3BHK in Mumbai\",\n    \"rent\": 30000.0,\n    \"roomsAvailable\": 2,\n    \"latitude\": 19.076,\n    \"longitude\": 72.877\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "http://localhost:8081/listings"
                    }
                },
                {
                    "name": "Search Nearby (Map View)",
                    "request": {
                        "method": "GET",
                        "url": "http://localhost:8081/location/nearby?lat=19.076&lng=72.877&radius=15"
                    }
                }
            ]
        },
        {
            "name": "3. Swipes & Matches & Chat",
            "item": [
                {
                    "name": "Swipe Right (Interest)",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"seekerId\": \"seeker_789\",\n    \"listingId\": \"list_001\",\n    \"type\": \"RIGHT\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "http://localhost:8081/swipes"
                    }
                },
                {
                    "name": "Approve Match",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"seekerId\": \"seeker_789\",\n    \"ownerId\": \"user_123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "http://localhost:8081/matches/approve"
                    }
                }
            ]
        },
        {
            "name": "4. Payments & Monetization",
            "item": [
                {
                    "name": "Razorpay Success Webhook",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"event\": \"subscription.charged\",\n    \"payload\": { \"userId\": \"seeker_789\" }\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "http://localhost:8081/payments/webhook"
                    }
                }
            ]
        }
    ]
