# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to GitHub

# AWS SDK default credential chain. Run `aws sso login --profile project-testing`.
# Never put AWS access keys in this file.
AWS_PROFILE=project-testing
AWS_REGION=ap-south-1

# DynamoDB
DYNAMODB_TABLE_NAME=FlatmateData
DYNAMODB_INITIALIZE_TABLE=true

# S3
S3_BUCKET=flatmate-photos

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Browser and WebSocket origins. Do not use * with authenticated requests.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT
JWT_SECRET=your_super_long_secret_key_here_minimum_32_chars

# SurePass KYC API (get token from https://surepass.io after registering)
SUREPASS_TOKEN=your_surepass_bearer_token_here

# Firebase Admin SDK (for FCM push notifications)
# Download from: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json
# For AWS, store a base64-encoded service-account JSON value in the runtime SecureString.
FIREBASE_SERVICE_ACCOUNT_BASE64=
