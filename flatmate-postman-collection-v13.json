{
  "info": {
    "_postman_id": "e8a9b2c3-1d4e-4f5a-9b1c-7e6d5c4b3a2f",
    "name": "FlatMate App API - v13 (Ultimate Full)",
    "description": "Complete Postman collection for the FlatMate App API. Restored every single endpoint from v8 plus new Match/Chat updates.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userId", "value": "+919876543210", "type": "string" },
    { "key": "listingId", "value": "listing_001", "type": "string" },
    { "key": "matchId", "value": "match_001", "type": "string" },
    { "key": "seekerId", "value": "+910000000000", "type": "string" },
    { "key": "ownerId", "value": "+919876543210", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Get Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        { "name": "1. Send OTP", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"phone\": \"{{userId}}\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/auth/otp/send", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "send"] } } },
        { "name": "2. Verify OTP", "event": [ { "listen": "test", "script": { "exec": [ "var json = pm.response.json();", "if (json.accessToken) pm.collectionVariables.set('token', json.accessToken);", "if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);" ], "type": "text/javascript" } } ], "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"phone\": \"{{userId}}\", \"otp\": \"123456\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/auth/otp/verify", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "verify"] } } },
        { "name": "3. Refresh Token", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"refreshToken\": \"{{refreshToken}}\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] } } },
        { "name": "4. Set Role", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"userId\": \"{{userId}}\", \"role\": \"SEEKER\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/auth/set-role", "host": ["{{baseUrl}}"], "path": ["auth", "set-role"] } } },
        { "name": "5. Switch Role", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"userId\": \"{{userId}}\", \"role\": \"OWNER\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/auth/switch-role", "host": ["{{baseUrl}}"], "path": ["auth", "switch-role"] } } }
      ]
    },
    {
      "name": "Profiles",
      "item": [
        { "name": "Get Profile", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/profiles/{{userId}}", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}"] } } },
        { "name": "Update Basic Profile", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"userId\": \"{{userId}}\", \"firstName\": \"Raj\", \"lastName\": \"Kumar\", \"gender\": \"MAN\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] } } },
        { "name": "Update Seeker Profile", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"userId\": \"{{userId}}\", \"seekerProfile\": {\"jobTitle\": \"Engineer\", \"smokingHabit\": \"NEVER\"}}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/profiles", "host": ["{{baseUrl}}"], "path": ["profiles"] } } },
        { "name": "Get KYC Upload URL", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/profiles/{{userId}}/kyc/upload-url?fileName=aadhar.jpg&type=document", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}", "kyc", "upload-url"], "query": [{ "key": "fileName", "value": "aadhar.jpg" }, { "key": "type", "value": "document" }] } } },
        { "name": "Complete KYC", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"userId\": \"{{userId}}\", \"documentType\": \"AADHAR_CARD\", \"documentImageUrl\": \"url_here\", \"selfieImageUrl\": \"url_here\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/profiles/kyc", "host": ["{{baseUrl}}"], "path": ["profiles", "kyc"] } } },
        { "name": "Register As Owner", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/profiles/{{userId}}/owner", "host": ["{{baseUrl}}"], "path": ["profiles", "{{userId}}", "owner"] } } }
      ]
    },
    {
      "name": "Listings",
      "item": [
        { "name": "Publish Listing", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"ownerId\": \"{{userId}}\", \"propertyName\": \"Sunrise\", \"rent\": 15000}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/listings", "host": ["{{baseUrl}}"], "path": ["listings"] } } },
        { "name": "Get All Listings", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/listings", "host": ["{{baseUrl}}"], "path": ["listings"] } } },
        { "name": "Get My Listings (Owner)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/listings/owner/{{userId}}", "host": ["{{baseUrl}}"], "path": ["listings", "owner", "{{userId}}"] } } },
        { "name": "Update Listing", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"propertyName\": \"Updated Name\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] } } },
        { "name": "Delete Listing", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/listings/{{listingId}}", "host": ["{{baseUrl}}"], "path": ["listings", "{{listingId}}"] } } }
      ]
    },
    {
      "name": "Location",
      "item": [
        { "name": "Index Locations", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/location/index", "host": ["{{baseUrl}}"], "path": ["location", "index"] } } },
        { "name": "Nearby Search", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/location/nearby?lat=12.97&lng=77.59&radius=10", "host": ["{{baseUrl}}"], "path": ["location", "nearby"], "query": [{ "key": "lat", "value": "12.97" }, { "key": "lng", "value": "77.59" }, { "key": "radius", "value": "10" }] } } }
      ]
    },
    {
      "name": "Matches & Swipes",
      "item": [
        { "name": "Swipe RIGHT", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"seekerId\": \"{{userId}}\", \"listingId\": \"{{listingId}}\", \"swipeType\": \"RIGHT\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/swipes", "host": ["{{baseUrl}}"], "path": ["swipes"] } } },
        { "name": "Get Listing Interests", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/swipes/listing/{{listingId}}/interests", "host": ["{{baseUrl}}"], "path": ["swipes", "listing", "{{listingId}}", "interests"] } } },
        { "name": "Approve Match", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"ownerId\": \"{{userId}}\", \"seekerId\": \"{{seekerId}}\", \"listingId\": \"{{listingId}}\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/matches/approve", "host": ["{{baseUrl}}"], "path": ["matches", "approve"] } } },
        { "name": "Create Match (Test Helper)", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"ownerId\": \"{{userId}}\", \"seekerId\": \"{{seekerId}}\", \"listingId\": \"{{listingId}}\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/matches/create", "host": ["{{baseUrl}}"], "path": ["matches", "create"] } } },
        { "name": "Get My Matches", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/matches/{{userId}}", "host": ["{{baseUrl}}"], "path": ["matches", "{{userId}}"] } } }
      ]
    },
    {
      "name": "Chat",
      "item": [
        { "name": "Get Chat History", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/chat/{{matchId}}/history", "host": ["{{baseUrl}}"], "path": ["chat", "{{matchId}}", "history"] } } },
        { "name": "Mark as Read", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/chat/{{matchId}}/read?userId={{userId}}", "host": ["{{baseUrl}}"], "path": ["chat", "{{matchId}}", "read"], "query": [{ "key": "userId", "value": "{{userId}}" }] } } },
        { "name": "Get Upload URL", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/chat/{{matchId}}/upload-url?fileName=msg.jpg", "host": ["{{baseUrl}}"], "path": ["chat", "{{matchId}}", "upload-url"], "query": [{ "key": "fileName", "value": "msg.jpg" }] } } }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        { "name": "Get Inbox", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/notifications/inbox/{{userId}}", "host": ["{{baseUrl}}"], "path": ["notifications", "inbox", "{{userId}}"] } } },
        { "name": "Save FCM Token", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\"userId\": \"{{userId}}\", \"fcmToken\": \"token_here\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/notifications/token", "host": ["{{baseUrl}}"], "path": ["notifications", "token"] } } }
      ]
    }
  ]
}
